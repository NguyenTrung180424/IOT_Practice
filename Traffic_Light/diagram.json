  "connections": [

    ["esp:25","r1:1","green"],
    ["r1:2","red:A","green"],
    ["red:C","esp:GND","black"],

    ["esp:26","r2:1","green"],
    ["r2:2","yellow:A","green"],
    ["yellow:C","esp:GND","black"],

    ["esp:27","green:A","green"],
    ["green:C","esp:GND","black"],

    ["esp:14","blue:A","green"],
    ["blue:C","esp:GND","black"],

    ["btn:1","esp:33","blue"],
    ["btn:2","esp:GND","black"],

    ["display:CLK","esp:18","green"],
    ["display:DIO","esp:19","green"],
    ["display:VCC","esp:3V3","red"],
    ["display:GND","esp:GND","black"],

    ["ldr:VCC","esp:3V3","red"],
    ["ldr:GND","esp:GND","black"],
    ["ldr:AO","esp:34","green"]
