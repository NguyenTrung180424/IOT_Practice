{
  "version": 1,
  "author": "Trung",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 100, "left": 150 },

    { "type": "wokwi-tm1637-7segment", "id": "display", "top": -20, "left": 180 },

    { "type": "wokwi-led", "id": "red", "top": 50, "left": 420, "attrs": { "color": "red" } },
    { "type": "wokwi-led", "id": "yellow", "top": 100, "left": 420, "attrs": { "color": "yellow" } },
    { "type": "wokwi-led", "id": "green", "top": 150, "left": 420, "attrs": { "color": "green" } },
    { "type": "wokwi-led", "id": "blue", "top": 200, "left": 420, "attrs": { "color": "blue" } },

    { "type": "wokwi-resistor", "id": "r1", "top": 50, "left": 380, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "r2", "top": 100, "left": 380, "attrs": { "value": "220" } },

    { "type": "wokwi-pushbutton", "id": "btn", "top": 220, "left": 300 },

    { "type": "wokwi-photoresistor-sensor", "id": "ldr", "top": 220, "left": 40 }
